{% extends "base.twig" %}

{% block title %}Login - Admin Panel{% endblock %}

{% block content %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow">
                <div class="card-header bg-primary text-white text-center">
                    <h4 class="mb-0">Admin Login</h4>
                </div>
                <div class="card-body">
                    {% if error %}
                        <div class="alert alert-error">{{ error }}</div>
                    {% endif %}
                    
                    <form method="POST" action="/login">
                        <div class="form-group mb-3">
                            <label for="username">Username</label>
                            <input type="text" class="form-control" id="username" name="username" required>
                        </div>
                        
                        <div class="form-group mb-3">
                            <label for="password">Password</label>
                            <input type="password" class="form-control" id="password" name="password" required>
                        </div>

                            <style>
                          .captcha-wrapper{
                            display:flex;
                            justify-content: center;
                            align-items:center;
                            gap:10px;
                        }

                        .captcha-image{
                            background:url('/uploads/bg6.png');
                            letter-spacing:4px;
                            font-size:26px;
                            font-weight:bold;
                            text-align:center;
                            color:#000;
                            height: 50px;
                           
                        }

                        .captcha-refresh{
                            height:40px;
                            width:45px;
                            display:flex;
                            align-items:center;
                            justify-content:center;
                        }

                            </style>

                            <div class="mb-3">
                            <label class="form-label">Captcha</label>

                            <div class="captcha-wrapper">

                                <input
                                    type="text"
                                    id="captchaCode"
                                    class="form-control captcha-image"
                                    value="{{ captcha_code }}"
                                    readonly
                                    oncopy="return false"
                                    oncut="return false"
                                    ondrag="return false"
                                >

                                <button type="button" class="btn btn-light captcha-refresh" onclick="refreshCaptcha()">
                                    <i class="fas fa-sync-alt"></i>
                                </button>

                            </div>
                        </div>

                        <div class="mb-3">
                            <input type="text" class="form-control" name="captcha" placeholder="Enter captcha" required>
                        </div>

                           

                        <button type="submit" class="btn btn-primary w-100">Login</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>

function refreshCaptcha(){

    fetch('/refresh-captcha')
    .then(res => res.json())
    .then(data => {
        document.getElementById('captchaCode').value = data.captcha;
    })
    .catch(err => console.log(err));

}

</script>
{% endblock %}