{% extends "admin/base.twig" %}

{% block title %}Dashboard{% endblock %}

{% set current_page = 'dashboard' %}

{% block content %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <h1 class="h3 mb-4">Dashboard</h1>
        </div>
    </div>
    
    <!-- Stats Cards -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-info">
                <h3>{{ stats.total_bookings }}</h3>
                <p>Total Bookings</p>
            </div>
            <i class="fas fa-bed"></i>
        </div>
        
        <div class="stat-card" style="background: linear-gradient(135deg, #e74c3c, #c0392b);">
            <div class="stat-info">
                <h3>{{ stats.pending_bookings }}</h3>
                <p>Pending Bookings</p>
            </div>
            <i class="fas fa-clock"></i>
        </div>
        
        <div class="stat-card" style="background: linear-gradient(135deg, #3498db, #2980b9);">
            <div class="stat-info">
                <h3>{{ stats.today_reservations }}</h3>
                <p>Today's Reservations</p>
            </div>
            <i class="fas fa-utensils"></i>
        </div>
        
        <div class="stat-card" style="background: linear-gradient(135deg, #f39c12, #e67e22);">
            <div class="stat-info">
                <h3>{{ stats.unread_messages }}</h3>
                <p>Unread Messages</p>
            </div>
            <i class="fas fa-envelope"></i>
        </div>
    </div>
    
    <div class="row">
        <!-- Recent Bookings -->
        <div class="col-lg-6 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Recent Room Bookings</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Guest</th>
                                    <th>Room</th>
                                    <th>Check In</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for booking in recentBookings %}
                                <tr>
                                    <td>#{{ booking.id }}</td>
                                    <td>{{ booking.guest_name }}</td>
                                    <td>{{ booking.room.room_number }}</td>
                                    <td>{{ booking.check_in|date('M d, Y') }}</td>
                                    <td>
                                        <span class="badge bg-{{ booking.status == 'confirmed' ? 'success' : (booking.status == 'pending' ? 'warning' : 'secondary') }}">
                                            {{ booking.status }}
                                        </span>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    <a href="/admin/bookings" class="btn btn-sm btn-primary">View All</a>
                </div>
            </div>
        </div>
        
        <!-- Recent Reservations -->
        <div class="col-lg-6 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Recent Restaurant Reservations</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Guest</th>
                                    <th>Date</th>
                                    <th>Time</th>
                                    <th>Guests</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for reservation in recentReservations %}
                                <tr>
                                    <td>#{{ reservation.id }}</td>
                                    <td>{{ reservation.guest_name }}</td>
                                    <td>{{ reservation.reservation_date|date('M d, Y') }}</td>
                                    <td>{{ reservation.reservation_time|date('g:i A') }}</td>
                                    <td>{{ reservation.guests }}</td>
                                    <td>
                                        <span class="badge bg-{{ reservation.status == 'confirmed' ? 'success' : (reservation.status == 'pending' ? 'warning' : 'secondary') }}">
                                            {{ reservation.status }}
                                        </span>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    <a href="/admin/reservations" class="btn btn-sm btn-primary">View All</a>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Revenue Card -->
    <div class="row">
        <div class="col-12">
            <div class="card bg-dark text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="card-title">Total Revenue</h5>
                            <h2 class="mb-0">{{currency}}{{ stats.revenue|number_format(2) }}</h2>
                        </div>
                        <i class="fas {{ currency_icon }} fa-4x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}