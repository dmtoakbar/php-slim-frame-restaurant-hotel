<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>{% block title %}Admin Panel{% endblock %} - Hotel & Restaurant</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
    
    {% block styles %}{% endblock %}
</head>
<body class="admin-body">
    <div class="admin-wrapper">
        <!-- Admin Sidebar -->
        <aside class="admin-sidebar">
            <nav class="nav">
                  <a class="sidebar-title" href="/admin">
                    <i class="fas fa-hotel"></i>
                    <span class="d-lg-inline">Restaurant & Hotel</span>
                </a>
                <a class="nav-link {% if current_page == 'dashboard' %}active{% endif %}" href="/admin">
                    <i class="fas fa-tachometer-alt"></i>
                    <span class="d-none d-lg-inline">Dashboard</span>
                </a>
                <a class="nav-link {% if current_page == 'rooms' %}active{% endif %}" href="/admin/rooms">
                    <i class="fas fa-bed"></i>
                    <span class="d-none d-lg-inline">Rooms</span>
                </a>
                <a class="nav-link {% if current_page == 'menu' %}active{% endif %}" href="/admin/menu">
                    <i class="fas fa-utensils"></i>
                    <span class="d-none d-lg-inline">Menu</span>
                </a>
                <a class="nav-link {% if current_page == 'bookings' %}active{% endif %}" href="/admin/bookings">
                    <i class="fas fa-calendar-check"></i>
                    <span class="d-none d-lg-inline">Bookings</span>
                </a>
                <a class="nav-link {% if current_page == 'reservations' %}active{% endif %}" href="/admin/reservations">
                    <i class="fas fa-clock"></i>
                    <span class="d-none d-lg-inline">Reservations</span>
                </a>
                <a class="nav-link {% if current_page == 'messages' %}active{% endif %}" href="/admin/messages">
                    <i class="fas fa-envelope"></i>
                    <span class="d-none d-lg-inline">Messages</span>
                </a>
                <a class="nav-link {% if current_page == 'gallery' %}active{% endif %}" href="/admin/gallery">
                    <i class="fas fa-images"></i>
                    <span class="d-none d-lg-inline">Gallery</span>
                </a>
                <a class="nav-link {% if current_page == 'users' %}active{% endif %}" href="/admin/users">
                    <i class="fas fa-users"></i>
                    <span class="d-none d-lg-inline">Users</span>
                </a>
                <a class="nav-link {% if current_page == 'settings' %}active{% endif %}" href="/admin/settings">
                    <i class="fas fa-cog"></i>
                    <span class="d-none d-lg-inline">Settings</span>
                </a>
                <a class="nav-link" href="/">
                    <i class="fas fa-globe"></i>
                    <span class="d-none d-lg-inline">View Site</span>
                </a>
                <a class="nav-link" href="/logout">
                    <i class="fas fa-sign-out-alt"></i>
                    <span class="d-none d-lg-inline">Logout</span>
                </a>
            </nav>
        </aside>
        
        <!-- Admin Content -->
        <main class="admin-content">
            <!-- Header -->
            <div class="d-none d-lg-block mb-3">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Admin Panel</h5>
                    <div>
                        <span class="me-2">{{ session.user_name }}</span>
                        <a href="/logout" class="btn btn-sm btn-outline-danger">
                            <i class="fas fa-sign-out-alt"></i>
                        </a>
                    </div>
                </div>
                <hr>
            </div>

            {% if flash.success %}
            <div class="alert alert-success alert-dismissible fade show">
                {{ flash.success[0] }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            {% endif %}

            {% if flash.error %}
            <div class="alert alert-danger alert-dismissible fade show">
                {{ flash.error[0] }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            {% endif %}
            
            <!-- Page Content -->
            {% block content %}{% endblock %}
        </main>
    </div>
    
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    
    <!-- Custom JS -->
    <script src="/js/main.js"></script>
    
    {% block scripts %}{% endblock %}
</body>
</html>