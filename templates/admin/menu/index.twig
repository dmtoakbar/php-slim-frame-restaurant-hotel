{% extends "admin/base.twig" %}

{% block title %}Manage Menu{% endblock %}

{% set current_page = 'menu' %}

{% block content %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">Manage Menu Items</h1>
        <div>
            <a href="/admin/menu-categories" class="btn btn-info me-2">
                <i class="fas fa-tags"></i> Manage Categories
            </a>
            <a href="/admin/menu/create" class="btn btn-primary">
                <i class="fas fa-plus"></i> Add New Item
            </a>
        </div>
    </div>
    
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Image</th>
                            <th>Name</th>
                            <th>Category</th>
                            <th>Price</th>
                            <th>Available</th>
                            <th>Featured</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in items %}
                        <tr>
                            <td>#{{ item.id }}</td>
                            <td>
                                <img src="/uploads/{{ item.image|default('default-food.jpg') }}" 
                                     alt="{{ item.name }}"
                                     style="width: 60px; height: 40px; object-fit: cover; border-radius: 5px;">
                            </td>
                            <td>{{ item.name }}</td>
                            <td>{{ item.category.name }}</td>
                            <td>{{currency}}{{ item.price|number_format(2) }}</td>
                            <td>
                                {% if item.is_available %}
                                    <span class="badge bg-success">Yes</span>
                                {% else %}
                                    <span class="badge bg-danger">No</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if item.is_featured %}
                                    <span class="badge bg-warning">Featured</span>
                                {% endif %}
                            </td>
                            <td>
                                <a href="/admin/menu/{{ item.id }}/edit" class="btn btn-sm btn-primary">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <button onclick="deleteMenuItem({{ item.id }})" class="btn btn-sm btn-danger">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="8" class="text-center">No menu items found</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
function deleteMenuItem(id) {
    if (confirm('Are you sure you want to delete this menu item?')) {
        fetch('/admin/menu/' + id, {
            method: 'DELETE'
        }).then(() => location.reload());
    }
}
</script>
{% endblock %}