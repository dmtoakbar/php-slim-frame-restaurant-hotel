{% extends "admin/base.twig" %}

{% block title %}Contact Messages{% endblock %}

{% set current_page = 'messages' %}

{% block content %}
<div class="container-fluid">
    <h1 class="h3 mb-4">Contact Messages</h1>
    
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Subject</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for message in messages %}
                        <tr class="{{ not message.is_read ? 'fw-bold' : '' }}">
                            <td>#{{ message.id }}</td>
                            <td>{{ message.name }}</td>
                            <td>{{ message.email }}</td>
                            <td>{{ message.subject }}</td>
                            <td>{{ message.created_at|date('M d, Y H:i') }}</td>
                            <td>
                                {% if message.is_read %}
                                    <span class="badge bg-secondary">Read</span>
                                {% else %}
                                    <span class="badge bg-warning">Unread</span>
                                {% endif %}
                            </td>
                            <td>
                                <button class="btn btn-sm btn-info" onclick="viewMessage({{ message.id }})">
                                    <i class="fas fa-eye"></i>
                                </button>
                                <button class="btn btn-sm btn-danger" onclick="deleteMessage({{ message.id }})">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="7" class="text-center">No messages found</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Message View Modal -->
<div class="modal fade" id="messageModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Message Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="messageContent">
                <!-- Loaded via AJAX -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" onclick="replyToMessage()">
                    <i class="fas fa-reply"></i> Reply
                </button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script>
function viewMessage(id) {
    $.ajax({
        url: '/admin/messages/' + id,
        method: 'GET',
        success: function(data) {
            $('#messageContent').html(data);
            new bootstrap.Modal(document.getElementById('messageModal')).show();
        }
    });
}

function deleteMessage(id) {
    if (confirm('Are you sure you want to delete this message?')) {
        window.location.href = '/admin/messages/' + id + '/delete';
    }
}

function replyToMessage() {
    var email = $('#messageContent').find('.message-email').text();
    window.location.href = 'mailto:' + email;
}
</script>
{% endblock %}