{
    "name": "hotel-restaurant/website",
    "description": "Hotel and Restaurant Website with Admin Panel",
    "type": "project",
    "require": {
        "php": ">=7.4",
        "slim/slim": "^4.11",
        "slim/psr7": "^1.6",
        "slim/twig-view": "^3.3",
        "slim/flash": "^0.4.0",
        "illuminate/database": "^10.0",
        "respect/validation": "^2.2",
        "vlucas/phpdotenv": "^5.5",
        "phpmailer/phpmailer": "^6.8",
        "league/flysystem": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8081 -t public",
        "migrate": "php database/migrate.php"
    }
}